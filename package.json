{
  "name": "district-quality-map",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.5",
  "scripts": {
    "dev": "next dev",
    "build": "bun run geo:reconcile && next build",
    "lint": "eslint .",
    "test": "bun test",
    "test:py": "python3 -m unittest discover scripts/tests",
    "audit": "bun pm audit",
    "geo:reconcile": "bun scripts/check_city_data.ts",
    "geo:build": "python3 scripts/city_compiler/cli.py build",
    "geo:validate": "python3 scripts/city_compiler/cli.py validate",
    "geo:compile": "python3 scripts/city_compiler/cli.py build",
    "geo:compile:validate": "python3 scripts/city_compiler/cli.py validate",
    "geo:compile:audit": "python3 scripts/city_compiler/cli.py audit",
    "geo:coverage": "python3 scripts/city_compiler/cli.py build",
    "geo:coverage:all": "python3 scripts/city_compiler/cli.py build lille nice && python3 scripts/city_compiler/cli.py validate lille nice",
    "geo:outlines": "bun scripts/build_city_outlines.ts",
    "geo:validate:all": "python3 scripts/city_compiler/cli.py build && python3 scripts/city_compiler/cli.py validate && bun scripts/build_city_outlines.ts && bun run build"
  },
  "dependencies": {
    "@deck.gl/layers": "^9.1.14",
    "@deck.gl/mapbox": "^9.1.14",
    "maplibre-gl": "^5.6.1",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@turf/helpers": "^7.3.5",
    "@turf/union": "^7.3.5",
    "@types/node": "^24.0.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.30.1",
    "eslint-config-next": "^16.2.10",
    "typescript": "^5.8.3"
  }
}
